{
  "name": "collaborative-editor-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo orchestration for the Collaborative Editor AI project",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "install:all": "node scripts/installAll.mjs",
    "dev:all": "node scripts/devAll.mjs",
    "dev:clean": "node scripts/devClean.mjs",
